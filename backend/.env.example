# Path to your Google service account key JSON file
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/gcp-service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
VLM_MODEL=gemini-2.5-flash-lite
AUTO_CROP_ENABLED=1
ROUTER_MODEL=gemini-2.0-flash-lite
TUTOR_MODEL=gemini-2.5-flash
TUTOR_MAX_OUTPUT_TOKENS=2400
WHISPER_MODEL=distil-large-v3
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8

# Chroma
CHROMA_ENABLED=0
CHROMA_COLLECTION=ta_course_clusters
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=
CHROMA_SIMILARITY_THRESHOLD=0.32

# MongoDB Atlas
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=ta
# Optional: auto run schema init at API startup
CORS_ORIGINS=http://localhost:8080
MONGO_INIT_ON_STARTUP=0
JWT_SECRET=change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=10080

# Optional: debug toggles
DEBUG_KEEP_AUDIO=0
DEBUG_AUDIO_DIR=debug-audio
